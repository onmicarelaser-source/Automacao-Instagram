## 📄 ARQUIVO 10: `.env.example` (COMPLETO)

```env
# Instagram Credentials
INSTAGRAM_USERNAME=seu_usuario
INSTAGRAM_PASSWORD=sua_senha
INSTAGRAM_ACCESS_TOKEN=seu_token

# API Settings
API_PORT=5000
API_HOST=0.0.0.0
DEBUG=False

# Scheduler Settings
SCHEDULER_TIMEZONE=America/Sao_Paulo
MAX_POSTS_PER_DAY=5
SCHEDULER_INTERVAL=3600

# Database (opcional)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=instagram_bot
DB_USER=postgres
DB_PASSWORD=senha

# Redis (opcional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/instagram_automation.log

# Security
SECRET_KEY=sua_chave_secreta
JWT_SECRET=sua_chave_jwt

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_email